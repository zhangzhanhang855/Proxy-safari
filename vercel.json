{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/proxy",
      "destination": "https://666jrmusic.ccwu.cc:2087/"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Content-Security-Policy", "value": "default-src 'self' 'unsafe-inline' 'unsafe-eval' wss: https: data:; frame-src *;" }
      ]
    }
  ]
}
